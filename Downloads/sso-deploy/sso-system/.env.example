# ════════════════════════════════════════
# 统一登录系统 SSO v2.0 - 环境变量
# 复制为 .env 并按需填写，未填写的接口功能不生效
# ════════════════════════════════════════

PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development

# JWT - 生产环境务必替换为随机长字符串
JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_RANDOM_64_CHARS
JWT_EXPIRES_IN=7d
SESSION_SECRET=CHANGE_THIS_IN_PRODUCTION_RANDOM_32_CHARS

# 短信服务商：volcengine | aliyun | tencent
SMS_PROVIDER=volcengine
SMS_CODE_EXPIRE=300
EMAIL_CODE_EXPIRE=600

CORS_ORIGIN=*
