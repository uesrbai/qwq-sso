# ════════════════════════════════════════
# 统一登录系统 SSO v2.0 - 环境变量
# 复制为 .env 并按需填写，未填写的接口功能不生效
# ════════════════════════════════════════

PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development

# JWT - 生产环境务必替换为随机长字符串
JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_RANDOM_64_CHARS
JWT_EXPIRES_IN=7d
SESSION_SECRET=CHANGE_THIS_IN_PRODUCTION_RANDOM_32_CHARS

# ══════════════════════════════════════════
# 消息分发中心 QWQ Message
# https://github.com/uesrbai/qwq-message
#
# v3.3.3 起短信和邮件全部通过分发中心发送，本系统不再直接对接
# 火山引擎/阿里云/腾讯云/SMTP/Zeabur Email 等服务商——
# 那些账号、模板、轮询、故障转移都配在分发中心那边。
# ══════════════════════════════════════════
QWQ_MESSAGE_URL=            # 分发中心根地址，如 https://msg.example.com（不带结尾斜杠）
QWQ_MESSAGE_KEY=            # qwq_live_xxx（生产）或 qwq_test_xxx（测试）
QWQ_MESSAGE_SMS_GROUP=      # 短信通道组标识，如 sms-16
QWQ_MESSAGE_EMAIL_GROUP=    # 邮件通道组标识，如 mail-1
QWQ_MESSAGE_SMS_TEMPLATE=   # 可选：短信模板号，填了走模板变量（变量名 code），不填发纯文本

SMS_CODE_EXPIRE=300
EMAIL_CODE_EXPIRE=600

CORS_ORIGIN=*

# ══════════════════════════════════════════
# 抖音开放平台
# https://developer.open-douyin.com → 创建网站应用
# ══════════════════════════════════════════
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
DOUYIN_REDIRECT_URI=

# ══════════════════════════════════════════
# 快手开放平台
# https://open.kuaishou.com → 创建应用
# ══════════════════════════════════════════
KUAISHOU_APP_ID=
KUAISHOU_APP_SECRET=
KUAISHOU_REDIRECT_URI=

# ══════════════════════════════════════════
# 小红书开放平台（需申请合作资质）
# https://developers.xiaohongshu.com
# ══════════════════════════════════════════
XHS_APP_ID=
XHS_APP_SECRET=
XHS_REDIRECT_URI=

# ══════════════════════════════════════════
# Bilibili 开放平台（需申请合作开发者）
# https://openhome.bilibili.com
# ══════════════════════════════════════════
BILIBILI_CLIENT_ID=
BILIBILI_CLIENT_SECRET=
BILIBILI_REDIRECT_URI=

# ══════════════════════════════════════════
# Google OAuth 2.0
# https://console.cloud.google.com → API 和服务 → 凭证 → 创建 OAuth 2.0 客户端
# ══════════════════════════════════════════
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ══════════════════════════════════════════
# Apple Sign In (Sign in with Apple)
# https://developer.apple.com → Certificates → Identifiers & Keys
# 需要 Apple Developer 账号（$99/年），回调必须 HTTPS
# APPLE_PRIVATE_KEY: .p8 文件内容（多行），建议写成单行并用 \n 换行
# ══════════════════════════════════════════
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=

# ── Didit KYC（didit.me - 每月500次免费）──
DIDIT_API_KEY=              # 从 business.didit.me 获取
DIDIT_WORKFLOW_ID=          # 工作流 UUID
DIDIT_WEBHOOK_SECRET=       # Webhook 签名密钥（可选）

# ── Stripe Identity KYC ──
# STRIPE_SECRET_KEY 已在 Stripe 支付配置中定义，此处复用
STRIPE_WEBHOOK_SECRET=      # /webhook/kyc/stripe 端点的签名密钥 (whsec_...)
